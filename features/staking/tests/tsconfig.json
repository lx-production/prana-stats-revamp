{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": false,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "./**/*.ts",
    "../*.ts",
    "../../../constants/**/*.ts",
    "../../../types/**/*.ts"
  ],
  "exclude": ["../../../node_modules", "../../../dist"]
}
