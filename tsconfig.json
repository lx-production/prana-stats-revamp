{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "strict": false,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "components/**/*.ts",
    "components/**/*.tsx",
    "constants/**/*.ts",
    "features/**/*.ts",
    "features/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "types/**/*.ts",
    "utils/**/*.ts",
    "main.tsx",
    "hero3.tsx",
    "shader.tsx",
    "flutterShader.tsx",
    "spinningFavicon.ts",
    "vite-env.d.ts"
  ],
  "exclude": ["dist", "node_modules", "server", "scripts"]
}
