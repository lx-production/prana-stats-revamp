{
  "name": "prana-stats",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run serve\" \"npm run dev\"",
    "build": "vite build",
    "redeploy": "sudo systemctl stop prana-stats-revamp.service && npm run build && sudo systemctl restart prana-stats-revamp.service",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "fetch:staking-stats": "tsx scripts/fetch-staking-stats.ts",
    "scan:bonds:v2": "node --experimental-strip-types scripts/scan-bonds-v2.js",
    "update:bonds:v2": "node --experimental-strip-types scripts/update-bonds-v2.ts",
    "update:top:holders": "node --experimental-strip-types scripts/update-top-holding-addresses.js",
    "serve": "node --experimental-strip-types server/index.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.5.0",
    "ethers": "^6.15.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  }
}
