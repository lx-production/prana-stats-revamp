{
  "name": "prana-protocol",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.js",
    "dev:all": "concurrently -k -s first \"npm run serve:dev\" \"tsx scripts/wait-for-api.ts 4174 && npm run dev\"",
    "build": "vite build --config config/vite.config.js",
    "redeploy": "sudo systemctl stop prana-stats-revamp.service && npm run build && sudo systemctl restart prana-stats-revamp.service",
    "preview": "vite preview --config config/vite.config.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:server",
    "test:server": "node --import tsx --test 'server/tests/**/*.test.ts'",
    "test:staking": "node --import tsx --test 'features/staking/**/*.test.ts'",
    "test:rate-limit": "node --import tsx --test server/tests/rateLimit.test.ts",
    "fetch:staking-stats": "tsx scripts/fetch-staking-stats.ts",
    "scan:bonds:v2": "tsx scripts/scan-bonds-v2.ts",
    "update:bonds:v2": "tsx scripts/update-bonds-v2.ts",
    "update:top:holders": "tsx scripts/update-top-holding-addresses.ts",
    "serve": "tsx server/index.ts",
    "serve:dev": "PORT=4174 tsx server/index.ts"
  },
  "dependencies": {
    "@ethersproject/providers": "^5.8.0",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.101.2",
    "@uniswap/router-sdk": "^2.11.0",
    "@uniswap/sdk-core": "^7.18.0",
    "@uniswap/smart-order-router": "^4.31.10",
    "@uniswap/v2-sdk": "^4.21.0",
    "@uniswap/v3-sdk": "^3.31.0",
    "ethers": "^6.15.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "three": "^0.160.0",
    "viem": "^2.53.1",
    "wagmi": "^3.6.21"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.0"
  },
  "overrides": {
    "axios": "1.18.1",
    "@ethersproject/providers": {
      "ws": "8.21.1"
    },
    "ethers": {
      "ws": "8.21.1"
    },
    "viem": {
      "ws": "8.21.1"
    }
  }
}
