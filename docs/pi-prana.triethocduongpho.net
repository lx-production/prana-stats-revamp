server {
    listen 80 default_server;
    server_name prana.triethocduongpho.net;

    # Main app (stats + lazy /stake/ + API) — Node serves the SPA shell and
    # Vite `dist/` assets. When Accept-Encoding includes gzip, Node prefers
    # sibling `*.gz` files produced at build (gzip level 9).
    location / {
        proxy_pass http://127.0.0.1:4173;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Preserve client Accept-Encoding so Node can select precompressed bodies.
        proxy_set_header Accept-Encoding $http_accept_encoding;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Redirect bare path to trailing slash
    location = /bond {
        return 301 /bond/;
    }

    # React Bonding app (legacy static SPA)
    # Prefer on-disk `*.gz` via gzip_static (precompress at bond build time).
    # Without a sibling .gz, nginx falls back to the uncompressed file.
    location ^~ /bond/ {
        alias /var/www/html/prana/bond/;
        try_files $uri $uri/ /bond/index.html;
        gzip_static on;

        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        add_header Pragma "no-cache" always;
        add_header Expires "0" always;
    }

    # React Bonding assets — hashed files should ship with `*.gz` siblings.
    location ^~ /bond/assets/ {
        alias /var/www/html/prana/bond/assets/;
        gzip_static on;
        gzip_types application/javascript text/css text/javascript;

        expires max;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
        etag on;
        add_header Access-Control-Allow-Origin "*" always;
    }

    access_log /var/log/nginx/prana.access.log;
    error_log /var/log/nginx/prana.error.log;
}
