# Define rate limiting zones
limit_req_zone $binary_remote_addr zone=ip_req_limit:10m rate=50r/s;
limit_conn_zone $binary_remote_addr zone=conn_limit:10m;

# Redirect common bots/scrapers on / to the markdown summary API
map $http_user_agent $is_summary_client {
    default 0;
    ~*(bot|crawler|spider|scraper|GPTBot|ChatGPT-User|ClaudeBot|anthropic|PerplexityBot|Bytespider|Applebot|facebookexternalhit|Twitterbot|LinkedInBot|Slurp|bingbot|Googlebot|Baiduspider|SemrushBot|AhrefsBot|curl|wget|python-requests|Go-http-client|HeadlessChrome|Puppeteer|Playwright) 1;
}

# HTTP to HTTPS redirect
server {
    listen 80;
    server_name prana.triethocduongpho.net;

    return 301 https://$server_name$request_uri;
}

# HTTPS server block
server {
    listen 443 ssl;
    server_name prana.triethocduongpho.net;

    # Rate limiting
    limit_req zone=ip_req_limit burst=40 nodelay;
    limit_conn conn_limit 20;
    limit_req_status 429;
    limit_conn_status 429;

    # SSL configuration
    ssl_certificate /etc/letsencrypt/live/content.triethocduongpho.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/content.triethocduongpho.net/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers "ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384";

    # Gzip at the public edge
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/javascript
        application/javascript
        application/json
        image/svg+xml
        model/gltf-binary;

    # Block common scan paths
    location ~ ^/(\.env|ab2|alive\.php|teorema505|\.git|wp-|phpunit|config\.php|admin\.php) {
        limit_req zone=ip_req_limit burst=1 nodelay;
        return 444;
    }

    # Prana is not WordPress — block WP scanner paths explicitly
    location = /xmlrpc.php {
        return 404;
    }
    
    error_page 429 /rate_limited.html;
    location = /rate_limited.html {
        root /var/www/html/prana;
        internal;
    }

    # New stats app Vite assets: /assets/*
    location ^~ /assets/ {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Old stake/bond hashed assets: /stake/assets/* and /bond/assets/*
    location ~ ^/(stake|bond)/assets/ {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Let VPS handle compression
        proxy_set_header Accept-Encoding "";

        # Long browser cache for hashed assets
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;

        # Keep this if you still want asset CORS
        add_header Access-Control-Allow-Origin "*" always;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Homepage: send bots/scrapers to the markdown summary instead of the React UI
    location = / {
        if ($is_summary_client) {
            return 302 /api/summary;
        }

        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_cache off;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
    }

    # Everything else:
    # - new stats app HTML/API/JSON at /
    # - old /stake SPA HTML
    # - old /bond SPA HTML
    #
    # Do not force cache headers here.
    # Preserve whatever Pi nginx / Node app sends.
    location / {
        proxy_pass http://127.0.0.1:9000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;

        proxy_cache off;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
    }

    access_log /var/log/nginx/prana.access.log;
    error_log /var/log/nginx/prana.error.log;
}
